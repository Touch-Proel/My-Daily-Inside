{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article or blog post entry in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Technology & AI", "Productivity", "Online Income", "Lifestyle", "Personal Growth"] },
        "author": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "image": { "type": "string", "format": "uri" },
        "readingTime": { "type": "string" }
      },
      "required": ["slug", "title", "content", "category", "author", "publishedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A topical category for blog posts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message sent via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog post entries."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of blog categories."
    },
    "/messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of messages from the contact form."
    }
  }
}
